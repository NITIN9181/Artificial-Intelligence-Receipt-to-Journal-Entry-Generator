# ──────────────────────────────────────────────────
# Backend Environment Variables (.env)
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────

# --- Supabase ---
SUPABASE_URL=https://<YOUR_SUPABASE_URL>
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>  # NEVER expose in frontend
SUPABASE_JWT_SECRET=<YOUR_SUPABASE_JWT_SECRET>  # Found in Supabase Dashboard > Settings > API > JWT Secret

# --- Database ---
DATABASE_URL=postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB>

# --- NVIDIA NIM (cloud inference) ---
NVIDIA_NIM_API_KEY=<YOUR_NVIDIA_NIM_API_KEY>  # NEVER expose in frontend

# --- LLM ---
LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct

# --- Ollama (local fallback — uncomment to use) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-vl:7b

# --- Application ---
MAX_UPLOAD_SIZE_MB=20
MAX_RECEIPTS_PER_DAY=20
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
